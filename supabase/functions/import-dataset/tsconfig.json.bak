{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@supabase/supabase-js": ["../../../web/node_modules/@supabase/supabase-js"]
    }
  },
  "include": ["index.ts", "deno-globals.d.ts"]
}
